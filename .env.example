# =============================================================================
# SURAKSHA.AI BACKEND - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control - it contains sensitive information

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Full PostgreSQL connection string with PostGIS extension
# Format: postgresql://username:password@hostname:port/database?sslmode=require
# Examples:
#   - Supabase: postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres?sslmode=require
#   - Neon: postgresql://username:password@ep-cool-darkness-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
#   - Local: postgresql://postgres:password@localhost:5432/kaval_db?sslmode=prefer
DATABASE_URL="postgresql://postgres:password@localhost:5432/suraksha_db?sslmode=prefer"

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Strong random string for JWT token signing (minimum 64 characters)
# Generate with: openssl rand -base64 64
JWT_SECRET="your-super-secure-jwt-secret-key-minimum-64-characters-long-please-change-this"

# JWT token expiration time (in seconds)
# 3600 = 1 hour, 86400 = 24 hours, 604800 = 7 days
JWT_EXPIRES_IN=3600

# =============================================================================
# WEBAUTHN CONFIGURATION
# =============================================================================
# Relying Party (RP) name - displayed to users during authentication
WEBAUTHN_RP_NAME="Suraksha.ai"

# Relying Party ID - your domain without protocol (e.g., suraksha.ai, localhost)
# For development: localhost
# For production: your-domain.com
WEBAUTHN_RP_ID="localhost"

# Full origin URL where your frontend is hosted
# For development: http://localhost:3000
# For production: https://your-domain.com
WEBAUTHN_ORIGIN="http://localhost:3000"

# =============================================================================
# S3-COMPATIBLE STORAGE (CLOUDFLARE R2 PREFERRED)
# =============================================================================
# S3-compatible endpoint URL
# Cloudflare R2: https://your-account-id.r2.cloudflarestorage.com
# AWS S3: https://s3.your-region.amazonaws.com
# MinIO (local): http://localhost:9000
S3_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"

# S3 Access Key ID
S3_ACCESS_KEY_ID="your-s3-access-key-id"

# S3 Secret Access Key
S3_SECRET_ACCESS_KEY="your-s3-secret-access-key"

# S3 Bucket name for storing media files
# Must be created before starting the application
S3_BUCKET_NAME="suraksha-media"

# S3 Region (required for AWS S3, optional for R2)
S3_REGION="auto"

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Port number for the Express server
PORT=3001

# Node environment (development, staging, production)
NODE_ENV="development"

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# CORS allowed origins (comma-separated list)
# For development: http://localhost:3000
# For production: https://your-domain.com,https://www.your-domain.com
CORS_ORIGINS="http://localhost:3000"

# Rate limiting - requests per window per IP
RATE_LIMIT_REQUESTS=100

# Rate limiting - window duration in minutes
RATE_LIMIT_WINDOW_MINUTES=15

# =============================================================================
# FILE UPLOAD LIMITS
# =============================================================================
# Maximum file size for SOS audio clips (in bytes)
# 10MB = 10485760 bytes
MAX_AUDIO_SIZE=10485760

# Maximum file size for violation media files (in bytes)
# 50MB = 52428800 bytes
MAX_MEDIA_SIZE=52428800

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level (error, warn, info, debug)
LOG_LEVEL="info"

# Enable request logging (true/false)
ENABLE_REQUEST_LOGGING=true

# =============================================================================
# GEOSPATIAL CONFIGURATION
# =============================================================================
# Default radius for geospatial queries (in kilometers)
DEFAULT_RADIUS_KM=5

# Maximum allowed radius for geospatial queries (in kilometers)
MAX_RADIUS_KM=50

# =============================================================================
# OPTIONAL: REDIS CONFIGURATION (FOR CACHING)
# =============================================================================
# Redis connection URL for caching (optional)
# Format: redis://username:password@hostname:port/database
# REDIS_URL="redis://localhost:6379/0"

# =============================================================================
# OPTIONAL: MONITORING AND OBSERVABILITY
# =============================================================================
# Application name for monitoring
APP_NAME="suraksha-ai-backend"

# Application version
APP_VERSION="1.0.0"

# Enable health check endpoint (true/false)
ENABLE_HEALTH_CHECK=true

# =============================================================================
# EMAIL NOTIFICATIONS (FOR SURAKSHA.AI BACKEND)
# =============================================================================
# Enable/disable email notifications (true/false)
EMAIL_ENABLED=false

# Gmail address to send emails from
# Note: You need to generate a Gmail App Password, NOT use your regular password
# See: https://support.google.com/accounts/answer/185833
EMAIL_USER="your-email@gmail.com"

# Gmail App Password (16 characters, format: xxxx xxxx xxxx xxxx)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD="your-app-password"

# Admin email address to receive notifications
ADMIN_EMAIL="admin@suraksha.ai"