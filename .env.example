VITE_API_BASE_URL=http://localhost:3002/api/v1
# Backend base URL. Change to production URL before deployment.

VITE_APP_NAME=Kaval PWA
# Display name used in the manifest and headers.

VITE_WEBAUTHN_RP_ID=localhost
# Must match the backend WEBAUTHN_RP_ID exactly.

VITE_DEFAULT_LAT=12.9716
VITE_DEFAULT_LNG=77.5946
# Default map center - Bengaluru city centre.

VITE_MAP_RADIUS_KM=5
# Default heatmap query radius in kilometers.
